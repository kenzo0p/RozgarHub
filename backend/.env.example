# ─── RozgarHub Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env files — they contain secrets.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017/rozgarhub

# ─── Redis (optional — app works without it, just skips caching) ──────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate one with:  openssl rand -hex 32
# In production, a value containing "change-this"/"secret-key" is rejected at boot.
SECRET_KEY=your-jwt-secret-key-change-this-in-production

# ─── Cloudinary (file uploads) ────────────────────────────────────────────────
CLOUD_NAME=your-cloud-name
CLOUD_API_KEY=your-api-key
CLOUD_API_SECRET=your-api-secret

# ─── CORS ──────────────────────────────────────────────────────────────────────
# In production this must NOT be localhost (rejected at boot).
CORS_ORIGIN=http://localhost:5173

# ─── Error monitoring (optional) ──────────────────────────────────────────────
# Set to your Sentry DSN to enable exception forwarding (see utils/monitoring.ts).
# SENTRY_DSN=

# ─── Feature Flags (optional — all default to true) ──────────────────────────
# FF_AI_MATCHING=true
# FF_NOTIFICATIONS=true
# FF_SAVED_JOBS=true
# FF_AUDIT_LOGGING=true
# FF_REDIS_CACHE=true
# FF_PASSWORD_RESET=true
