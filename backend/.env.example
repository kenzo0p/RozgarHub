# ─── RozgarHub Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env files — they contain secrets.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/rozgarhub

# ─── Redis (optional — app works without it, just skips caching) ──────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
SECRET_KEY=your-jwt-secret-key-change-this-in-production

# ─── Cloudinary (file uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Feature Flags (optional — all default to true) ──────────────────────────
# FF_AI_MATCHING=true
# FF_NOTIFICATIONS=true
# FF_SAVED_JOBS=true
# FF_AUDIT_LOGGING=true
# FF_REDIS_CACHE=true
# FF_PASSWORD_RESET=true
